{:paths ["src"]
 :deps {org.clojure/clojure {:mvn/version "1.11.1"}

        top.kzre/krro-util-pool {:mvn/version "1.0-SNAPSHOT"}
        top.kzre/krro-util-math {:mvn/version "1.0-SNAPSHOT"}
        top.kzre/color-utils {:mvn/version "1.0-SNAPSHOT"}
        top.kzre/krro-util-tile {:mvn/version "1.0-SNAPSHOT"}
        top.kzre/curve-bezier2d {:mvn/version "1.0-SNAPSHOT"}
        top.kzre/smooth  {:mvn/version "1.0-SNAPSHOT"}
        top.kzre/value-mapping {:mvn/version "1.0-SNAPSHOT"}
        top.kzre/pixelshape {:mvn/version "1.0-SNAPSHOT"}


        com.taoensso/timbre {:mvn/version "6.3.1"}
        com.taoensso/tufte {:mvn/version "2.6.3"}
        }

 :aliases {:test {:extra-paths ["test"]
                  :extra-deps {org.clojure/test.check {:mvn/version "1.1.0"}
